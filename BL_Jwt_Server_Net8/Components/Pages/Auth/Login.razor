@page "/login"
@using BL_Jwt_Server_Net8.DTOs
@using BL_Jwt_Server_Net8.Services
@using BL_Jwt_Server_Net8.States
@using Microsoft.AspNetCore.Components.Authorization
@using static BL_Jwt_Server_Net8.DTOs.CustomResponses

@inject IAccountService AccountService
@inject NavigationManager NavMan
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

@rendermode InteractiveServer

<div class="container">
    <div class="row">
        <div class="col-sm-4">
            <h2>Login</h2>
            <EditForm Model="LoginDTO" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="LoginDTO.Email" />
                </div>
                <div class="form-group mt-3">
                    <label class="form-label">Password</label>
                    <InputText class="form-control" @bind-Value="LoginDTO.Password" type="password" />
                </div>
                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-primary">Login</button>
                </div>
                <ValidationSummary />
            </EditForm>
        </div>
    </div>
</div>

@code {
    LoginDTO LoginDTO = new();

    private async Task HandleSubmit()
    {
        LoginResponse response = await AccountService.Login(LoginDTO);
        if (!response.Flag)
        {
            await JS.InvokeVoidAsync("alert", response.Message);
            return;
        }

        var authStateProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
        authStateProvider.UpdateAuthenticationState(response.Token);
        NavMan.NavigateTo("/", forceLoad: true);
    }
}
